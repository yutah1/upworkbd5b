rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "islamohi453@gmail.com" ||
        request.auth.token.email == "yuta81134@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    // Settings collection
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Premium Jobs
    match /premiumJobs/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Deposits
    match /deposits/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Facebook Sell Posts
    match /facebookSellPosts/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Facebook Sell Submissions
    match /facebookSellSubmissions/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Gmail Sell Posts
    match /gmailSellPosts/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Gmail Sell Submissions
    match /gmailSellSubmissions/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Micro Jobs
    match /microJobs/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User Micro Jobs
    match /userMicroJobs/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.posterId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.posterId == request.auth.uid);
    }

    // Daily Tasks
    match /dailyTasks/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Withdrawals
    match /withdrawals/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Target Bonuses
    match /targetBonuses/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Gift Bonuses
    match /giftBonuses/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Welcome Bonuses
    match /welcomeBonuses/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Welcome Bonus Submissions
    match /welcomeBonusSubmissions/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Monthly Salaries
    match /monthlySalaries/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Monthly Salary Submissions
    match /monthlySalarySubmissions/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Leadership Salaries
    match /leadershipSalaries/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Leadership Salary Submissions
    match /leadershipSalarySubmissions/{document} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Video Earn Tasks
    match /videoEarnTasks/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
